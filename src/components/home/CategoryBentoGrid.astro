---
import SectionKicker from '../ui/SectionKicker.astro';
import SectionHeading from '../ui/SectionHeading.astro';

const categories = [
  {
    title: 'Spices',
    summary: 'Single-origin flavor pillars selected for potency and aroma.',
    image: 'https://images.unsplash.com/photo-1532336414038-cf19250c5757?auto=format&fit=crop&w=1600&q=80',
  },
  {
    title: 'Pulses',
    summary: 'Protein-rich staples sorted for texture, color, and purity.',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuAbnf-NkzoiD64naQHj7xbNVxTgnCM0vYT5W8fO0MwvPmJtHyyHe_XTWnNvhBrhThO8krULkgZUVjTB7Y46YNhbC8FQLxDZalVJILJq-U9Achj1KKRIlDSsuhZSzA0kaQsDBYZ4xKfdpXGuFyIfB-gPto5JC21hhGNEZ7cv6vAmbtNjKe7He3Cqc2fota1-0Nuc-4GFQSpHQWxvOLXozcBSJO6l82Qiw3V8bm9iHrf3iDzQH6Q8gANeH68mL-Ljl4KKLAagc3FSAJE',
  },
  {
    title: 'Grains',
    summary: 'Heritage grains curated for balanced nutrition and comfort.',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDstt1IrHSlWH5ZBOzcU0nv7Pc7t9pd8uVR7IbicyYcpiqdTg_kv3W1subBYScxPFOrQkyr0fAJ48eowawiX4GHBCGowO3_vzlm_klicW5m_NkshrlXKZeYLtevdjQf6Oz0Dn4O5Kliy303eDBbbcLueUybaUeNgAj3XQ_nfCF4bErS92I32l9O8QzUNMMvEMoNBV6zynPZIilLW979abed9M3RUTIyE5yrGXLFnt0y1CdKpeAaBIPjyI1zVEcj24I_1ViikhZpLSI',
  },
];
---

<section class="bg-dough py-24">
  <div class="mx-auto max-w-7xl px-6 md:px-10">
    <div class="max-w-3xl">
      <SectionKicker text="Curated Pantry" />
      <div class="mt-4">
        <SectionHeading title="Mastering Flavor Through Heritage Crops" align="left" />
      </div>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-12">
      <article class="group overflow-hidden rounded-[2rem] bg-surface p-4 shadow-[0_16px_30px_rgba(62,39,35,0.08)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_34px_rgba(62,39,35,0.12)] md:col-span-7">
        <img
          src={categories[0].image}
          alt={categories[0].title}
          class="w-full h-48 object-cover rounded-t-xl md:h-[28rem]"
          loading="lazy"
        />
        <div class="px-2 pb-3 pt-5 md:px-3">
          <span class="font-body text-xs font-semibold uppercase tracking-[0.2em] text-clove/55">01</span>
          <h3 class="mt-2 font-heading text-4xl text-clove">{categories[0].title}</h3>
          <p class="mt-3 max-w-lg font-body text-base leading-relaxed text-clove/75">
            {categories[0].summary}
          </p>
        </div>
      </article>

      <div class="grid grid-cols-1 gap-6 md:col-span-5">
        {
          categories.slice(1).map((category, index) => (
            <article class="group overflow-hidden rounded-[2rem] bg-surface p-4 shadow-[0_16px_30px_rgba(62,39,35,0.08)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_20px_34px_rgba(62,39,35,0.12)]">
              <img
                src={category.image}
                alt={category.title}
                class="w-full h-48 object-cover rounded-t-xl"
                loading="lazy"
              />
              <div class="px-2 pb-3 pt-5 md:px-3">
                <span class="font-body text-xs font-semibold uppercase tracking-[0.2em] text-clove/55">
                  0{index + 2}
                </span>
                <h3 class="mt-2 font-heading text-3xl text-clove">{category.title}</h3>
                <p class="mt-3 font-body text-sm leading-relaxed text-clove/72">{category.summary}</p>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
