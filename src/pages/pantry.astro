  },
  {
    title: 'Crimson Masoor',
    price: 'INR 180',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuAbnf-NkzoiD64naQHj7xbNVxTgnCM0vYT5W8fO0MwvPmJtHyyHe_XTWnNvhBrhThO8krULkgZUVjTB7Y46YNhbC8FQLxDZalVJILJq-U9Achj1KKRIlDSsuhZSzA0kaQsDBYZ4xKfdpXGuFyIfB-gPto5JC21hhGNEZ7cv6vAmbtNjKe7He3Cqc2fota1-0Nuc-4GFQSpHQWxvOLXozcBSJO6l82Qiw3V8bm9iHrf3iDzQH6Q8gANeH68mL-Ljl4KKLAagc3FSAJE',
  },
  {
    title: 'Vintage Basmati',
    price: 'INR 890',
    image:
      'https://lh3.googleusercontent.com/aida-public/AB6AXuDstt1IrHSlWH5ZBOzcU0nv7Pc7t9pd8uVR7IbicyYcpiqdTg_kv3W1subBYScxPFOrQkyr0fAJ48eowawiX4GHBCGowO3_vzlm_klicW5m_NkshrlXKZeYLtevdjQf6Oz0Dn4O5Kliy303eDBbbcLueUybaUeNgAj3XQ_nfCF4bErS92I32l9O8QzUNMMvEMoNBV6zynPZIilLW979abed9M3RUTIyE5yrGXLFnt0y1CdKpeAaBIPjyI1zVEcj24I_1ViikhZpLSI',
  },
