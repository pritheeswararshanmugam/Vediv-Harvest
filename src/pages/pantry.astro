---

<BaseLayout
  title="The Pantry | Vedic Harvest"
  description="Explore Vedic Harvest pantry essentials, from single-origin spices to heritage grains."
>
  <FloatingNav />

  <main class="pb-24 pt-32">
    <section class="max-w-6xl mx-auto px-4 rounded-[2.2rem] bg-surface py-14 md:px-14 md:py-16">
      <p class="font-body text-xs font-semibold uppercase tracking-[0.2em] text-clove/60">Curated Collection</p>
      <h1 class="mt-4 font-heading text-5xl leading-tight text-clove md:text-6xl">The Ancestral Pantry</h1>
      <p class="mt-6 max-w-3xl font-body text-lg leading-relaxed text-clove/78">
        A focused catalog of high-integrity staples selected for aroma, nutrition, and everyday cooking confidence.
      </p>
    </section>

    <section class="max-w-6xl mx-auto px-4 mt-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      {
        products.map((product) => (
          <article class="overflow-hidden rounded-[2rem] bg-dough p-4 shadow-[0_14px_28px_rgba(62,39,35,0.08)] transition-transform duration-500 hover:-translate-y-2">
            <img
              src={product.image}
              alt={product.title}
              class="h-56 w-full rounded-t-xl object-cover"
              loading="lazy"
            />
            <div class="px-2 pb-3 pt-5">
              <h2 class="font-heading text-3xl text-clove">{product.title}</h2>
              <p class="mt-2 font-body text-base font-semibold text-clove/80">{product.price}</p>
            </div>
          </article>
        ))
      }
    </section>
  </main>

  <FooterArchive />
</BaseLayout>
